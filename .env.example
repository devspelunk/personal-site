# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_DB=directus
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# ── Directus ────────────────────────────────────────────────
DIRECTUS_SECRET=replace-with-random-string   # Session encryption key
DIRECTUS_TOKEN=replace-with-static-token     # Read-only token for Next.js SDK
DIRECTUS_ADMIN_EMAIL=admin@example.com       # Bootstrap/API setup user
DIRECTUS_ADMIN_PASSWORD=<REQUIRED_CHANGE>    # Set a strong password before first bootstrap
# Directus API base URL: bootstrap, and Flow "Content Revalidation Webhook" (slug fetch uses DIRECTUS_INTERNAL_URL, falling back to NEXT_PUBLIC_DIRECTUS_URL if unset). Pass DIRECTUS_TOKEN into the Directus process for that flow.
DIRECTUS_INTERNAL_URL=http://localhost:8055

# ── Shared (Directus + Next.js) ─────────────────────────────
REVALIDATION_SECRET=replace-with-random-string  # Webhook auth secret

# ── Next.js ─────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
NEXT_PUBLIC_DIRECTUS_URL=https://cms.yourdomain.com
NEXT_PUBLIC_FEATURE_MUSIC=false              # Set to true to enable music section
NEXT_PUBLIC_UMAMI_WEBSITE_ID=                # Umami website ID (optional; enables analytics script)
NEXT_PUBLIC_UMAMI_URL=                       # Self-hosted Umami script URL, e.g. https://analytics.yourdomain.com/script.js

# ── AI (Directus extension) ─────────────────────────────────
OPENROUTER_API_KEY=

# ── Social Publishing (Directus extension) ──────────────────
LINKEDIN_ACCESS_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
BLUESKY_IDENTIFIER=
BLUESKY_APP_PASSWORD=

# ── Umami ───────────────────────────────────────────────────
UMAMI_DATABASE_URL=postgresql://postgres:changeme@postgres:5432/umami
UMAMI_APP_SECRET=replace-with-random-string

# ── Resume Import Script ─────────────────────────────────────
RESUME_PDF_PATH=/absolute/local/path/to/resume.pdf   # Never commit the PDF
DIRECTUS_ADMIN_TOKEN=replace-with-admin-token         # Admin token for write access (script only)
