# Local Next.js development overrides
# Copy this file to .env.development.local and fill in the values from your .env
#
#   cp .env.development.local.example .env.development.local
#
# Next.js loads .env.development.local with higher priority than .env in dev
# mode, so these overrides take effect without modifying the shared .env file.

NEXT_PUBLIC_DIRECTUS_URL=http://localhost:8055
NEXT_PUBLIC_SITE_URL=http://localhost:3000

NEXT_PUBLIC_UMAMI_WEBSITE_ID=
NEXT_PUBLIC_UMAMI_URL=

# Copy these values from your .env file
DIRECTUS_TOKEN=replace-with-static-token
REVALIDATION_SECRET=replace-with-random-string
